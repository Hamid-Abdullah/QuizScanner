<?xml version="1.0" encoding="utf-8"?>
<!-- activity_main.xml — AR camera view + overlays -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000">

    <!-- AR camera background (handled by ARCore renderer) -->
    <SurfaceView
        android:id="@+id/ar_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- AR tick/cross overlay (drawn on top of camera feed) -->
    <com.quizscanner.OverlayView
        android:id="@+id/ar_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top status bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#88000000"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_qr"
            android:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Point camera at quiz sheet"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif" />

        <ToggleButton
            android:id="@+id/btn_flash"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:textOn=""
            android:textOff=""
            android:background="@drawable/bg_toggle" />
    </LinearLayout>

    <!-- Score display (bottom of screen, shown after grading) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#CC000000">

        <TextView
            android:id="@+id/tv_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone"
            android:layout_gravity="center" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="Save to Batch CSV"
            android:backgroundTint="#2563EB"
            android:textColor="#FFFFFF"
            android:visibility="gone" />
    </LinearLayout>

</FrameLayout>
